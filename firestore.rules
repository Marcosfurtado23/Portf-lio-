rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars)
    //   - role: string (required, max 100 chars)
    //   - category: string (required, max 100 chars)
    //   - image: string (required, valid URL, max 1000 chars)
    //   - gallery: list (optional, array of strings)
    //   - order: number (optional)
    //   - createdAt: timestamp (required, immutable)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Allow the specific user email to be the admin
      return isAuthenticated() && 
             request.auth.token.email == "marcossilva192024@gmail.com";
    }

    function isValidUrl(url) {
      return url is string && url.size() <= 1000 &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProject(data) {
      return hasRequiredFields(['title', 'role', 'category', 'image', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'role', 'category', 'image', 'gallery', 'order', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() <= 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             isValidUrl(data.image) &&
             (!('gallery' in data) || data.gallery is list) &&
             (!('order' in data) || data.order is number) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      // Anyone can read the portfolio projects
      allow read: if true;
      
      // Only admin can create
      allow create: if isAdmin() && 
                    isValidProject(request.resource.data) &&
                    request.resource.data.createdAt == request.time;
                    
      // Only admin can update
      allow update: if isAdmin() && 
                    isValidProject(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt; // Immutable
                    
      // Only admin can delete
      allow delete: if isAdmin();
    }
  }
}
